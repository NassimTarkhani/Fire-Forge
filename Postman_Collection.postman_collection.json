        {
            "name": "Register User",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "// Automatically save auth token and user_id from registration response",
                            "if (pm.response.code === 201) {",
                            "    var jsonData = pm.response.json();",
                            "    if (jsonData.access_token) {",
                            "        pm.collectionVariables.set(\"auth_token\", jsonData.access_token);",
                            "        console.log(\"✓ Saved auth token\");",
                            "    }",
                            "    if (jsonData.user && jsonData.user.id) {",
                            "        pm.collectionVariables.set(\"user_id\", jsonData.user.id);",
                            "        console.log(\"✓ Saved user_id: \" + jsonData.user.id);",
                            "    }",
                            "    if (jsonData.credits) {",
                            "        console.log(\"✓ Free credits granted: \" + jsonData.credits);",
                            "    }",
                            "    console.log(\"\\n⚡ Registration successful! Now create your API key via /auth/api-keys.\");",
                            "}"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"newuser@example.com\",\n    \"name\": \"New User\",\n    \"password\": \"StrongPass123!\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/register",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "register"
                    ]
                },
                "description": "Register a new user account with email/password and receive 50 free credits.\n\nResponse includes:\n- access_token (session token)\n- user.id\n- credits\n\nThen call /auth/api-keys to generate your API key."
            }
        },
