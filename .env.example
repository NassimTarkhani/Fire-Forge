# Application Settings
APP_NAME=FireForge API Gateway
DEBUG=false

# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# Firecrawl Configuration
# URL of your self-hosted Firecrawl instance
FIRECRAWL_BASE_URL=http://localhost:3002
FIRECRAWL_TIMEOUT=300

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Admin Configuration
# Generate a secure random key for admin operations (use a strong password generator)
ADMIN_MASTER_KEY=change-me-to-a-secure-random-key

# Polar Payment Configuration
# Get these from your Polar dashboard: https://polar.sh/dashboard
POLAR_ACCESS_TOKEN=your-polar-access-token-here
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret-here
POLAR_ORGANIZATION_ID=your-polar-organization-id-here
